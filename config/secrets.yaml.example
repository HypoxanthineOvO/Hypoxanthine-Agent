providers:
  VSPLab:
    api_base: "http://api.vsplab.cn/v1"
    api_key: "PLACEHOLDER_VSPLAB_OPENAI_KEY"

  VSPLab_Gemini:
    api_base: "http://api.vsplab.cn/antigravity"
    api_key: "PLACEHOLDER_VSPLAB_ANTIGRAVITY_KEY"

  VSPLab_Claude:
    api_base: "http://api.vsplab.cn/antigravity"
    api_key: "PLACEHOLDER_VSPLAB_ANTIGRAVITY_KEY"

  Hiapi:
    api_base: "https://hiapi.online/v1"
    api_key: "sk-xxx"

  Volcengine:
    api_base: "https://ark.cn-beijing.volces.com/api/v3"
    api_key: "xxx"

  Dashscope:
    api_base: "https://dashscope.aliyuncs.com/compatible-mode/v1"
    api_key: "sk-xxx"

  volcengine_kimi:
    api_key: "PLACEHOLDER_KIMI_KEY"
    api_base: "PLACEHOLDER_KIMI_API_BASE"

  minimax:
    api_key: "PLACEHOLDER_MINIMAX_KEY"

  zhipu:
    api_key: "PLACEHOLDER_ZHIPU_KEY"

  volcengine_coding:
    api_key: "PLACEHOLDER_VOLCENGINE_CODING_KEY"
    api_base: "https://ark.cn-beijing.volces.com/api/coding/v3"

  openai:
    api_key: "PLACEHOLDER_OPENAI_KEY"
    api_base: "https://api.openai.com/v1"

  volcano:
    api_key: "PLACEHOLDER_VOLCANO_EMBEDDING_KEY"
    api_base: "https://ark.cn-beijing.volces.com/api/v3"

services:
  email:
    accounts:
      - name: "主邮箱"
        host: "imap.example.com"
        port: 993
        username: "user@example.com"
        password: "PLACEHOLDER_EMAIL_PASSWORD"
        folder: "INBOX"
        use_ssl: true
  hypo_coder:
    base_url: "http://localhost:11451"   # Hypo-Coder 地址
    agent_token: "your-coder-agent-token-here"
    webhook_secret: "your-webhook-secret"  # 用于验证回调真实性
    webhook_url: "http://localhost:8765/api/coder/webhook"  # 可选，建议使用本机可回调地址
    incremental_output_enabled: false  # 启用 GET /api/tasks/{task_id}/output 增量输出轮询
  hypo_info:
    base_url: "http://localhost:<info-port>"  # Hypo-Info 地址
  notion:
    integration_secret: "secret_xxx"  # Notion Internal Integration Secret
    default_workspace: "Hypoxanthine's Notion"
    todo_database_id: ""  # 可选，Heartbeat 待办推送用的数据库 ID
  probe:
    token: "your-probe-token-here"
    screenshot_dir: "memory/probe_screenshots"
  qq:
    # NapCat WS Server 地址，用于接收 OneBot v11 事件；常见为 3009。
    napcat_ws_url: "ws://127.0.0.1:3009/onebot/v11/ws"
    # NapCat WS Server 的 token；为空时不传。
    napcat_ws_token: ""
    # NapCat HTTP API 地址，用于主动发送 QQ 消息。
    napcat_http_url: "http://127.0.0.1:3000"
    # 如果你的 NapCat HTTP API 没开 token，可保留为空字符串。
    napcat_http_token: ""
    # 机器人自己的 QQ 号。
    bot_qq: "123456789"
    # 允许和 Agent 对话的 QQ 号白名单。
    allowed_users:
      - "10001"
  qq_bot:
    # QQ 官方机器人 AppID（Open Platform）
    app_id: ""
    # QQ 官方机器人 AppSecret
    app_secret: ""
    # 启用官方 QQ Bot 通道；启用后优先于 NapCat
    enabled: false
    # 可选：当需要发送本地图片时，供 QQ 服务器回源拉取的公网地址
    # 例如 https://bot.example.com
    public_base_url: ""
  wewe_rss:
    enabled: false
    base_url: "http://10.15.88.94:4000"
    auth_code: "PLACEHOLDER_WEWE_RSS_AUTH_CODE"
    login_timeout_seconds: 180
    poll_interval_seconds: 3
  weixin:
    enabled: false
    token_path: "memory/weixin_auth.json"
    allowed_users: []
    # 首次使用前需运行 scripts/demo_weixin.py 扫码登录
    # 登录成功后 token 会持久化到 token_path
  feishu:
    # 飞书应用 App ID
    app_id: ""
    # 飞书应用 App Secret
    app_secret: ""
  bilibili:
    cookie: ""
  weibo:
    cookie: ""
  weread:
    cookie: ""
  zhihu:
    cookie: ""
  tavily:
    api_key: "PLACEHOLDER_TAVILY_API_KEY"
